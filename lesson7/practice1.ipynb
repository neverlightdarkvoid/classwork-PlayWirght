   "source": [
    "### While 迴圈"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "b72fa59f-a66f-4a22-aec3-10e36463a5ac",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "6\n",
      "5\n",
      "4\n",
      "3\n",
      "2\n",
      "1\n",
      "離開後 a 為 0\n"
     ]
    }
   ],
   "source": [
    "# while1.py\n",
    "a = 6\n",
    "while a > 0:\n",
    "    print(a)\n",
    "    a -= 1 \n",
    "print(\"離開後 a 為\", a)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "90326a6b-6b4f-4bad-99ab-f6df3fe2310a",
   "metadata": {},
   "source": [
    "### 計算 2-10 所有偶數的總和"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "36231f6f-d215-4b1f-b701-71a532ee0621",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "第1次迴圈的i=2,總合為2\n",
      "第2次迴圈的i=4,總合為6\n",
      "第3次迴圈的i=6,總合為12\n",
      "第4次迴圈的i=8,總合為20\n",
      "第5次迴圈的i=10,總合為30\n"
     ]
    }
   ],
   "source": [
    "total = 0\n",
    "i = 2\n",
    "while i <= 10:\n",
    "    total += i\n",
    "    print(f\"第{i//2}次迴圈的i={i},總合為{total}\")\n",
    "    i += 2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "71536ed2-a226-4bf9-a6c3-0cf5646d5c52",
   "metadata": {},
